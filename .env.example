PORT=3015
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Groq is the preferred learning-kit provider when GROQ_API_KEY is set.
# If neither GROQ_API_KEY nor ANTHROPIC_API_KEY is present, FocusCut falls back to transcript-powered demo content.
# If OPENAI_API_KEY is missing, FocusCut falls back to browser speech for narration.
